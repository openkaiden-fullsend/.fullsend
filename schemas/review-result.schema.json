{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review-result.schema.json",
  "title": "Review Agent Result",
  "description": "Structured output from the review agent, validated by the harness before the post-script runs (ADR 0022).",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "pr_number", "repo"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["approve", "request-changes", "comment", "failure"]
    },
    "pr_number": { "type": "integer", "minimum": 1 },
    "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
    "head_sha": { "type": "string", "minLength": 7 },
    "body": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" },
      "minItems": 1
    },
    "reason": {
      "type": "string",
      "enum": ["tool-failure", "missing-context", "ambiguous-findings", "token-limit"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "action": { "const": "approve" } }, "required": ["action"] },
      "then": { "required": ["body", "head_sha"] }
    },
    {
      "if": { "properties": { "action": { "const": "request-changes" } }, "required": ["action"] },
      "then": { "required": ["body", "head_sha", "findings"] }
    },
    {
      "if": { "properties": { "action": { "const": "comment" } }, "required": ["action"] },
      "then": { "required": ["body", "head_sha"] }
    },
    {
      "if": { "properties": { "action": { "const": "failure" } }, "required": ["action"] },
      "then": { "required": ["reason"] }
    }
  ],
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["severity", "category", "file", "description"],
      "properties": {
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
        "category": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "description": { "type": "string", "minLength": 1 },
        "remediation": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
